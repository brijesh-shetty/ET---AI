# Copy to .env and fill in. Never commit .env.

# === LLM ===
ANTHROPIC_API_KEY=                  # Claude API key (https://console.anthropic.com)
CLAUDE_MODEL_SYNTHESIS=claude-opus-4-8
CLAUDE_MODEL_CLASSIFY=claude-haiku-4-5-20251001

# === Signal sources ===
AISSTREAM_API_KEY=                  # free signup at https://aisstream.io
GDELT_BASE_URL=https://api.gdeltproject.org/api/v2
NEWSAPI_KEY=                        # https://newsapi.org free tier 100/day
EIA_API_KEY=                        # https://www.eia.gov/opendata
ALPHA_VANTAGE_KEY=                  # https://www.alphavantage.co commodity prices
OFAC_SDN_URL=https://www.treasury.gov/ofac/downloads/sdn.xml

# === Multi-commodity (no key APIs, just base URLs / scrape hints) ===
PPAC_BASE_URL=https://www.ppac.gov.in
WORLDSTEEL_DATA_PATH=./data/fixtures/coal_imports.json
USGS_MCS_DATA_PATH=./data/fixtures/critical_minerals.json
MNRE_SOLAR_DATA_PATH=./data/fixtures/solar_imports.json

# === Map tiles ===
MAPBOX_PUBLIC_TOKEN=                # optional; falls back to OSM

# === Service ===
BACKEND_HOST=0.0.0.0
BACKEND_PORT=8000
FRONTEND_PORT=5173
LOG_LEVEL=INFO
CACHE_DIR=./.cache
FIXTURES_DIR=./data/fixtures
ALLOW_LIVE_INGEST=false             # set true to enable live API calls; false uses fixtures
