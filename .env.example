# Copy to .env and fill in. Never commit .env.

# === LLM ===
GEMINI_API_KEY=                     # Google Gemini API key (https://aistudio.google.com/apikey)
GEMINI_MODEL=gemini-2.5-flash
GEMINI_MODEL_FAST=gemini-2.5-flash-lite-preview-06-17

# === Signal sources ===
AISSTREAM_API_KEY=                  # free signup at https://aisstream.io
GDELT_BASE_URL=https://api.gdeltproject.org/api/v2
NEWSAPI_KEY=                        # https://newsapi.org free tier 100/day
EIA_API_KEY=                        # https://www.eia.gov/opendata
ALPHA_VANTAGE_KEY=                  # https://www.alphavantage.co commodity prices
OFAC_SDN_URL=https://www.treasury.gov/ofac/downloads/sdn.xml

# VEDAS (ISRO Space Applications Centre) — Indian energy infrastructure layers
# (oil/gas pipelines, refineries). Register at https://vedas.sac.gov.in/vconsole
VEDAS_API_KEY=                      # your VEDAS API Centre key
VEDAS_BASE_URL=https://vedas.sac.gov.in

# === Multi-commodity (no key APIs, just base URLs / scrape hints) ===
PPAC_BASE_URL=https://www.ppac.gov.in
WORLDSTEEL_DATA_PATH=./data/fixtures/coal_imports.json
USGS_MCS_DATA_PATH=./data/fixtures/critical_minerals.json
MNRE_SOLAR_DATA_PATH=./data/fixtures/solar_imports.json

# === Map tiles ===
MAPBOX_PUBLIC_TOKEN=                # optional; backend-side reference
# The frontend reads VITE_MAPBOX_PUBLIC_TOKEN from frontend/.env (Vite only
# exposes vars with the VITE_ prefix to the browser). Set the same value
# there as VITE_MAPBOX_PUBLIC_TOKEN=pk.eyJ... to use Mapbox dark tiles in
# the Digital Twin. Without it, DigitalTwin uses free CartoDB dark tiles.
VITE_MAPBOX_PUBLIC_TOKEN=

# === Notifications ===
SLACK_WEBHOOK_URL=                  # optional; incoming webhook for alert push

# === Service ===
BACKEND_HOST=0.0.0.0
BACKEND_PORT=8000
FRONTEND_PORT=5173
LOG_LEVEL=INFO
CACHE_DIR=./.cache
FIXTURES_DIR=./data/fixtures
ALLOW_LIVE_INGEST=false             # set true to enable live API calls; false uses fixtures
